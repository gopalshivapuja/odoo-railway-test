<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================
         Custom Header
         Matches moaradvisory.com: logo + uppercase nav + social icons
         ============================================================ -->
    <record id="header_moar" model="ir.ui.view">
        <field name="name">MOAR Advisory Header</field>
        <field name="type">qweb</field>
        <field name="key">theme_moar_advisory.header_moar</field>
        <field name="inherit_id" ref="website.layout"/>
        <field name="mode">extension</field>
        <field name="arch" type="xml">
            <xpath expr="//header//nav" position="replace">
                <nav class="navbar navbar-expand-lg navbar-light py-2">
                    <div class="container">
                        <!-- Logo -->
                        <t t-call="website.placeholder_header_brand">
                            <t t-set="_link_class" t-valuef="navbar-brand"/>
                        </t>

                        <!-- Mobile toggle -->
                        <button class="navbar-toggler" type="button"
                                data-bs-toggle="collapse"
                                data-bs-target="#moar_nav"
                                aria-controls="moar_nav"
                                aria-expanded="false"
                                aria-label="Toggle navigation">
                            <span class="navbar-toggler-icon"/>
                        </button>

                        <!-- Nav links -->
                        <div class="collapse navbar-collapse" id="moar_nav">
                            <ul class="navbar-nav mx-auto">
                                <t t-foreach="website.menu_id.child_id" t-as="submenu">
                                    <t t-call="website.submenu">
                                        <t t-set="item_class" t-valuef="nav-item"/>
                                        <t t-set="link_class" t-valuef="nav-link"/>
                                    </t>
                                </t>
                            </ul>

                            <!-- Social icons -->
                            <div class="d-flex align-items-center ms-3">
                                <a href="https://www.linkedin.com/company/moar-advisory/"
                                   target="_blank" rel="noopener"
                                   class="s_moar_header_social"
                                   aria-label="LinkedIn">
                                    <i class="fa fa-linkedin"/>
                                </a>
                                <a href="https://www.youtube.com/@MOARAdvisory"
                                   target="_blank" rel="noopener"
                                   class="s_moar_header_social"
                                   aria-label="YouTube">
                                    <i class="fa fa-youtube-play"/>
                                </a>
                            </div>
                        </div>
                    </div>
                </nav>
            </xpath>
        </field>
    </record>

    <!-- ============================================================
         Custom Footer
         3-column: tagline+social | Quick Links | Contact Us
         ============================================================ -->
    <record id="footer_moar" model="ir.ui.view">
        <field name="name">MOAR Advisory Footer</field>
        <field name="type">qweb</field>
        <field name="key">theme_moar_advisory.footer_moar</field>
        <field name="inherit_id" ref="website.layout"/>
        <field name="mode">extension</field>
        <field name="arch" type="xml">
            <xpath expr="//div[@id='footer']" position="replace">
                <div id="footer" class="oe_structure oe_structure_solo"
                     t-ignore="true" t-if="not no_footer">
                    <section style="background-color: #1a2954; padding: 60px 0 40px;">
                        <div class="container">
                            <div class="row">
                                <!-- Column 1: Brand -->
                                <div class="col-lg-4 mb-4 mb-lg-0">
                                    <h5 style="color: #fff; font-weight: 700; font-size: 20px; margin-bottom: 16px;">
                                        Expertise that Accelerates<br/>Your Business Growth
                                    </h5>
                                    <p style="color: rgba(255,255,255,0.7); font-size: 14px; margin-bottom: 20px;">
                                        Advice You Can Trust,<br/>Experience You Can Use.
                                    </p>
                                    <div>
                                        <a href="https://www.linkedin.com/company/moar-advisory/"
                                           target="_blank" rel="noopener"
                                           class="s_moar_social_icon">
                                            <i class="fa fa-linkedin"/>
                                        </a>
                                        <a href="https://www.youtube.com/@MOARAdvisory"
                                           target="_blank" rel="noopener"
                                           class="s_moar_social_icon">
                                            <i class="fa fa-youtube-play"/>
                                        </a>
                                    </div>
                                </div>

                                <!-- Column 2: Quick Links -->
                                <div class="col-lg-4 mb-4 mb-lg-0">
                                    <h5 style="color: #fff; font-weight: 700; font-size: 16px; margin-bottom: 16px;">
                                        Quick Links
                                    </h5>
                                    <ul class="list-unstyled" style="margin: 0; padding: 0;">
                                        <li class="mb-2"><a href="/about" style="color: rgba(255,255,255,0.65); font-size: 14px; text-decoration: none;">About</a></li>
                                        <li class="mb-2"><a href="/our-leaders" style="color: rgba(255,255,255,0.65); font-size: 14px; text-decoration: none;">Our Leaders</a></li>
                                        <li class="mb-2"><a href="/case-studies" style="color: rgba(255,255,255,0.65); font-size: 14px; text-decoration: none;">Case Studies</a></li>
                                        <li class="mb-2"><a href="/blog" style="color: rgba(255,255,255,0.65); font-size: 14px; text-decoration: none;">MOAR Lens</a></li>
                                        <li class="mb-2"><a href="/media" style="color: rgba(255,255,255,0.65); font-size: 14px; text-decoration: none;">Media</a></li>
                                        <li class="mb-2"><a href="/contactus" style="color: rgba(255,255,255,0.65); font-size: 14px; text-decoration: none;">Contact Us</a></li>
                                    </ul>
                                </div>

                                <!-- Column 3: Contact -->
                                <div class="col-lg-4">
                                    <h5 style="color: #fff; font-weight: 700; font-size: 16px; margin-bottom: 16px;">
                                        Contact Us
                                    </h5>
                                    <p style="color: rgba(255,255,255,0.7); font-size: 14px; font-weight: 700; margin-bottom: 4px;">
                                        Get Closer
                                    </p>
                                    <p style="color: rgba(255,255,255,0.65); font-size: 14px; line-height: 1.6; margin-bottom: 16px;">
                                        MOAR Advisory<br/>
                                        1st Floor, 611, 2nd Cross Rd,<br/>
                                        3rd Block, Koramangala,<br/>
                                        Bengaluru, Karnataka 560034
                                    </p>
                                    <p style="color: rgba(255,255,255,0.7); font-size: 14px; font-weight: 700; margin-bottom: 4px;">
                                        Email
                                    </p>
                                    <p>
                                        <a href="mailto:contact@moaradvisory.com"
                                           style="color: rgba(255,255,255,0.65); font-size: 14px; text-decoration: none;">
                                            contact@moaradvisory.com
                                        </a>
                                    </p>
                                </div>
                            </div>
                        </div>
                    </section>
                    <!-- Copyright bar -->
                    <section style="background-color: #1a2954; border-top: 1px solid rgba(255,255,255,0.08); padding: 16px 0;">
                        <div class="container">
                            <p class="text-center mb-0" style="color: rgba(255,255,255,0.4); font-size: 13px;">
                                MOAR Advisory | Business Advisory Services | GCC Services
                            </p>
                        </div>
                    </section>
                </div>
            </xpath>
        </field>
    </record>

</odoo>
